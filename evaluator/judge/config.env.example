# Copie para juiz/config.env e ajuste no servidor de avaliação

# PostgreSQL — ranking (db_ingestao)
PG_HOST=localhost
PG_PORT=5432
PG_USER=homelab_postgres
PG_PASSWORD=altere_me
PG_DB_RANKING=db_ingestao

# PostgreSQL — dados de negócio (db_empresas)
PG_DB_EMPRESAS=db_empresas

# Docker — container Postgres (run-sql.sh / avaliador)
PG_CONTAINER=postgres_db

# S3-compatível / MinIO (opcional — alvo de laboratório na avaliação; fixe tag de release no docker-compose)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=marketing-leads

# Limites de volume (ajustar conforme dataset oficial)
VOLUME_MIN=500000
VOLUME_MAX=15000000

# Participante default para run-sql.sh (dq, volume, seed)
DEFAULT_PARTICIPANTE=renan_python

# Docker — rede compartilhada com postgres_db e minio (S3 lab)
DOCKER_NETWORK=
DATA_VOLUME=/caminho/para/dados:/data:ro

# ------------------------------------------------------------------------------
# Perfil do dataset oficial (estimativa de timeout)
# 5 zips ~1 GB; arquivo 1 ~28M linhas (~2 GB); outros 4 ~5M linhas cada
# 7 colunas origem + 3 derivadas; ~48M linhas / ~3,5 GB a processar
# ------------------------------------------------------------------------------
DATA_ZIP_COUNT=5
DATA_COMPRESSED_MB=1024
DATA_LINES_FILE1=28000000
DATA_LINES_OTHERS_EACH=5000000
DATA_FILES_OTHERS=4
DATA_SOURCE_COLUMNS=7
DATA_DERIVED_COLUMNS=3
DATA_UNCOMPRESSED_MB=3500
PIPELINE_ROWS_PER_SEC_FLOOR=5000
PIPELINE_THROUGHPUT_FLOOR_MBPS=2.0
PIPELINE_TIMEOUT_MARGIN_PCT=25
PIPELINE_TIMEOUT_ROUND_SEC=300

# Timeout do pipeline — se omitido, calculado automaticamente (~3h20m com os valores acima)
PIPELINE_TIMEOUT_SEC=12000

# Build da imagem do participante (não conta no tempo do pipeline; limita uso do host)
BUILD_TIMEOUT_SEC=900
BUILD_CPU_LIMIT=1.0
BUILD_MEM_LIMIT=1g

# SQL do juiz — fora do repositório público (só no servidor de avaliação)
# JUIZ_CONFIG=/opt/ingestao-juiz/config.env
# JUIZ_SQL_DIR=/opt/ingestao-juiz/sql
