# Copie para evaluator/judge/config.env e ajuste no servidor de avaliação

# PostgreSQL — conexão do juiz/scripts no HOST (fora do container do participante)
PG_HOST=localhost
PG_PORT=5432
PG_USER=homelab_postgres
PG_PASSWORD=altere_me
PG_DB_RANKING=db_ingestao

# PostgreSQL — dados de negócio (db_empresas)
PG_DB_EMPRESAS=db_empresas

# Docker — container Postgres (run-sql.sh / avaliador)
PG_CONTAINER=postgres_db
# Host injetado no container do participante (rede Docker; não use localhost)
PG_CONTAINER_HOST=postgres_db

# S3-compatível / MinIO (opcional — alvo de laboratório na avaliação; fixe tag de release no docker-compose)
MINIO_ENDPOINT=http://localhost:9000
# Endpoint injetado no container do participante (rede Docker)
S3_CONTAINER_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=marketing-leads

# Limites de volume — APERTADO: solução correta produz exatamente 25.031.418 registros
# (filtros determinísticos). Faixa estreita ±~0,5% em torno do valor exato.
VOLUME_MIN=24900000
VOLUME_MAX=25150000

# Score composto do ranking (menor = melhor). A função SQL recalcular_posicoes_ranking()
# usa estes pesos/refs — mantenha em sincronia com ranking_ingestao.sql e os docs.
SCORE_W_TEMPO=0.60
SCORE_W_RAM=0.25
SCORE_W_STORAGE=0.15
SCORE_REF_TEMPO_SEC=3600
SCORE_REF_RAM_MB=1024
SCORE_REF_STORAGE_MB=4096

# Participante default para run-sql.sh (dq, volume, seed)
DEFAULT_PARTICIPANTE=renan_python

# Docker — rede compartilhada com postgres_db e minio (S3 lab)
DOCKER_NETWORK=
DATA_VOLUME=/caminho/para/dados:/data:ro

# ------------------------------------------------------------------------------
# Perfil REAL do dataset oficial (medido por evaluator/scripts/profile_empresas.py)
# 10 zips ~1,26 GB comprimidos → ~5,0 GB descompactados (4,0x)
# Empresas0: 28.175.408 linhas (~2,1 GB) + 9 arquivos de 4.494.860 linhas
# total: 68.629.148 linhas; 7 colunas origem + 3 derivadas
# tabela final pós-filtros B2B: ~25.031.418 registros
# ------------------------------------------------------------------------------
DATA_ZIP_COUNT=10
DATA_COMPRESSED_MB=1290
DATA_LINES_FILE1=28175408
DATA_LINES_OTHERS_EACH=4494860
DATA_FILES_OTHERS=9
DATA_SOURCE_COLUMNS=7
DATA_DERIVED_COLUMNS=3
DATA_UNCOMPRESSED_MB=5112
DATA_FINAL_ROWS_EST=25031418

# Hardware do pipeline — RESTRITIVO por design (força cálculo de engenharia)
PIPELINE_CPU_LIMIT=2.0
PIPELINE_MEM_LIMIT=1g

# Orçamento do pipeline — HARD CAP de 60 min (não é dimensionado com folga)
# 68.629.148 linhas / 3600 s ⇒ ~19.000 linhas/s exigidas de ponta a ponta
PIPELINE_TIMEOUT_SEC=3600
PIPELINE_ROWS_PER_SEC_FLOOR=19000
PIPELINE_TIMEOUT_ROUND_SEC=60

# Build da imagem do participante (não conta no tempo do pipeline; limita uso do host)
BUILD_TIMEOUT_SEC=900
BUILD_CPU_LIMIT=1.0
BUILD_MEM_LIMIT=1g

# SQL do juiz — fora do repositório público (só no servidor de avaliação)
# JUIZ_CONFIG=/opt/ingestao-evaluator/judge/config.env
# JUIZ_SQL_DIR=/opt/ingestao-evaluator/judge/sql

# SMTP — relatório automático para o e-mail do participante (após a avaliação)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USER=projetos@exemplo.com
# SMTP_PASSWORD=altere_me
# SMTP_FROM=projetos@exemplo.com
